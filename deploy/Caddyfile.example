# --- mkv-to-mp3 site block for Caddy ---
# Add this as a NEW, separate site block in your existing Caddyfile (the one that
# already serves Foundry). Separate domains => no conflict with Foundry.
#
# Recommended setup: the Node service serves BOTH the static frontend and the
# /api, so Caddy just reverse-proxies the whole subdomain to it. The Node app
# listens on localhost:3000 only, so no extra cloud/OS firewall port is needed
# (Caddy already owns 80/443).
#
# Replace mkv.luxhauntedrealm.com with your chosen subdomain.

mkv.luxhauntedrealm.com {
	encode zstd gzip

	reverse_proxy localhost:3000 {
		# Multi-GB uploads + server-side encoding can take several minutes.
		transport http {
			read_timeout 30m
			write_timeout 30m
		}
	}
}

